# ---- LLM (Anthropic) ----
# Required. The funnel generator + refiner both use this key.
ANTHROPIC_API_KEY=

# Anthropic model id. Default is claude-opus-4-7 (~$0.29/quiz).
# Set claude-sonnet-4-6 (~$0.05/quiz) for cheaper iteration.
OLIVE_LLM_MODEL=claude-opus-4-7

# Cap on output tokens per generation. Specs rarely exceed 4k; 8k is a
# safe ceiling that still lets the long-form prompt finish.
OLIVE_LLM_MAX_TOKENS=8192

# ---- Supabase ----
# For local dev: run `pnpm supabase status` after `pnpm supabase start`
# to print these values. For hosted (Vercel): paste the Project URL +
# the publishable + secret keys from the Supabase dashboard. The
# variable names stay the same — the SDK accepts both the new
# sb_publishable_/sb_secret_ format and the legacy anon/service_role
# format transparently.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Optional ----
# CLI-only. The seed scripts print "share URLs" for the funnels they
# create; this variable is what they prefix the URL with. Runtime code
# (route handlers, pages) derives the URL from the request host headers
# instead, so unsetting this on Vercel is fine.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "1" to dump full LLM request/response payloads to the server log.
# Leave unset in production — the payloads include the entire system
# prompt and can be large.
# OLIVE_LLM_DEBUG=
