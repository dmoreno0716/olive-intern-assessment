# ---- LLM providers ----
# Pick one (or both). Your DECISIONS.md should explain which you chose and why.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Anthropic model used by the funnel generator + refiner.
# Defaults to claude-opus-4-7. Set claude-sonnet-4-6 for cheaper iteration.
OLIVE_LLM_MODEL=claude-opus-4-7
OLIVE_LLM_MAX_TOKENS=8192

# ---- Supabase (local dev defaults) ----
# Run `pnpm supabase status` after `pnpm supabase start` to print these values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
